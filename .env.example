# Copy to .env and adjust.

# ── Server ────────────────────────────────────────────────────────────────────
RULEKIT_ADDR=:8080
RULEKIT_ENV=development          # environment name (e.g. "production")

# ── Relational store ──────────────────────────────────────────────────────────
# Store backend: sqlite (default, zero-config) or postgres
RULEKIT_STORE=sqlite
RULEKIT_DATA_DIR=/data
# RULEKIT_STORE=postgres
# RULEKIT_DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=disable

# ── Blob store ────────────────────────────────────────────────────────────────
# Blob backend: fs (default, stored under RULEKIT_DATA_DIR/blobs) or s3
RULEKIT_BLOB_STORE=fs
# RULEKIT_BLOB_DIR=/data/blobs       # override default blob directory (fs only)
# RULEKIT_BLOB_STORE=s3
# RULEKIT_S3_BUCKET=my-bucket
# RULEKIT_S3_REGION=us-east-1        # use "auto" for Cloudflare R2
# RULEKIT_S3_ENDPOINT=               # custom endpoint, e.g. https://xxx.r2.cloudflarestorage.com
# RULEKIT_S3_ACCESS_KEY_ID=
# RULEKIT_S3_SECRET_ACCESS_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Both are required. Generate a secret with: openssl rand -hex 32
RULEKIT_JWT_SECRET=                  # signs all JWTs
RULEKIT_ADMIN_PASSWORD=              # password for the built-in admin account (login: email="admin")

# ── SMTP ──────────────────────────────────────────────────────────────────────
# Optional. When unset, OTP codes are printed to stdout (useful for local dev).
# RULEKIT_SMTP_HOST=smtp.example.com
# RULEKIT_SMTP_PORT=587
# RULEKIT_SMTP_USERNAME=
# RULEKIT_SMTP_PASSWORD=
# RULEKIT_SMTP_FROM=noreply@example.com
# RULEKIT_SMTP_USE_TLS=false         # true = implicit TLS (port 465) instead of STARTTLS

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Default allows the dashboard dev server.
# Use "*" to allow all origins (open dev environments only).
RULEKIT_CORS_ORIGINS=http://localhost:3001
# RULEKIT_CORS_ORIGINS=http://localhost:3001,https://dashboard.example.com
# RULEKIT_CORS_ORIGINS=*

# ── Rate limiting ─────────────────────────────────────────────────────────────
RULEKIT_RATE_LIMIT=false           # enable per-IP rate limiting
# RULEKIT_RATE_LIMIT_RPS=100        # requests per second (default: 100)
# RULEKIT_RATE_LIMIT_BURST=200      # burst size (default: 200)

# ── Network ───────────────────────────────────────────────────────────────────
RULEKIT_TRUSTED_PROXY=false        # trust X-Forwarded-For (set true behind a load balancer)
