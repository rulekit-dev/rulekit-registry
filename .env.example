# Copy to .env and adjust. Defaults work out of the box with SQLite and no auth.

RULEKIT_ADDR=:8080

# Store: sqlite (default) or postgres
RULEKIT_STORE=sqlite
RULEKIT_DATA_DIR=/data
# RULEKIT_STORE=postgres
# RULEKIT_DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=disable

# Blob store: fs (default) or s3
RULEKIT_BLOB_STORE=fs
# RULEKIT_BLOB_STORE=s3
# RULEKIT_S3_BUCKET=my-bucket
# RULEKIT_S3_REGION=us-east-1
# RULEKIT_S3_ENDPOINT=            # custom endpoint, e.g. Cloudflare R2
# RULEKIT_S3_ACCESS_KEY_ID=
# RULEKIT_S3_SECRET_ACCESS_KEY=

# Auth: none (default) or jwt
RULEKIT_AUTH=none
# RULEKIT_API_KEY=                # optional shared token for auth=none
# RULEKIT_AUTH=jwt
# RULEKIT_JWT_SECRET=             # openssl rand -hex 32
# RULEKIT_ADMIN_EMAIL=admin@example.com

# SMTP (auth=jwt only; omit to print OTP codes to stdout)
# RULEKIT_SMTP_HOST=smtp.example.com
# RULEKIT_SMTP_PORT=587
# RULEKIT_SMTP_USERNAME=
# RULEKIT_SMTP_PASSWORD=
# RULEKIT_SMTP_FROM=noreply@example.com
# RULEKIT_SMTP_USE_TLS=false

# CORS: comma-separated allowed origins, or * for all (leave unset to disable)
# RULEKIT_CORS_ORIGINS=http://localhost:3000
