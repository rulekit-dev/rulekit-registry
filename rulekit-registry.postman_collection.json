{
  "info": {
    "name": "rulekit-registry",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "workspace", "value": "default" },
    { "key": "ruleset_key", "value": "pricing" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "user_id", "value": "" },
    { "key": "key_id", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{base_url}}/healthz"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Admin login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "if (r.access_token) pm.collectionVariables.set('access_token', r.access_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin\",\n  \"password\": \"your-admin-password\"\n}"
            }
          }
        },
        {
          "name": "Request OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\"\n}"
            }
          }
        },
        {
          "name": "Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "if (r.access_token)  pm.collectionVariables.set('access_token', r.access_token);",
                  "if (r.refresh_token) pm.collectionVariables.set('refresh_token', r.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/v1/auth/verify",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"code\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Refresh token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "if (r.access_token)  pm.collectionVariables.set('access_token', r.access_token);",
                  "if (r.refresh_token) pm.collectionVariables.set('refresh_token', r.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/v1/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/v1/auth/logout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Workspaces",
      "item": [
        {
          "name": "List workspaces",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/workspaces?limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["v1", "workspaces"],
              "query": [
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Create workspace",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/v1/workspaces",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{workspace}}\",\n  \"description\": \"My workspace\"\n}"
            }
          }
        },
        {
          "name": "Get workspace",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v1/workspaces/{{workspace}}"
          }
        },
        {
          "name": "Delete workspace",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/v1/workspaces/{{workspace}}"
          }
        }
      ]
    },
    {
      "name": "Rulesets",
      "item": [
        {
          "name": "List rulesets",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/rulesets?workspace={{workspace}}&limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["v1", "rulesets"],
              "query": [
                { "key": "workspace", "value": "{{workspace}}" },
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Create ruleset",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/v1/rulesets",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workspace\": \"{{workspace}}\",\n  \"key\": \"{{ruleset_key}}\",\n  \"name\": \"Pricing Rules\",\n  \"description\": \"Rules for pricing decisions\"\n}"
            }
          }
        },
        {
          "name": "Get ruleset",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/rulesets/{{ruleset_key}}?workspace={{workspace}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "rulesets", "{{ruleset_key}}"],
              "query": [{ "key": "workspace", "value": "{{workspace}}" }]
            }
          }
        },
        {
          "name": "Delete ruleset",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/v1/rulesets/{{ruleset_key}}?workspace={{workspace}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "rulesets", "{{ruleset_key}}"],
              "query": [{ "key": "workspace", "value": "{{workspace}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Draft",
      "item": [
        {
          "name": "Get draft",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/rulesets/{{ruleset_key}}/draft?workspace={{workspace}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "rulesets", "{{ruleset_key}}", "draft"],
              "query": [{ "key": "workspace", "value": "{{workspace}}" }]
            }
          }
        },
        {
          "name": "Update draft DSL",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/v1/rulesets/{{ruleset_key}}/draft?workspace={{workspace}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "rulesets", "{{ruleset_key}}", "draft"],
              "query": [{ "key": "workspace", "value": "{{workspace}}" }]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dsl\": {\n    \"dsl_version\": \"v1\",\n    \"strategy\": \"first_match\",\n    \"schema\": {\n      \"amount\":   { \"type\": \"number\" },\n      \"currency\": { \"type\": \"enum\", \"options\": [\"IDR\", \"USD\"] },\n      \"weekend\":  { \"type\": \"boolean\" }\n    },\n    \"rules\": [\n      {\n        \"id\": \"r1\",\n        \"name\": \"High amount\",\n        \"when\": [{ \"field\": \"amount\", \"op\": \"gt\", \"value\": 50000000 }],\n        \"then\": { \"decision\": \"manual_review\" }\n      },\n      {\n        \"id\": \"r2\",\n        \"name\": \"Weekend surcharge\",\n        \"when\": [{ \"field\": \"weekend\", \"op\": \"eq\", \"value\": true }],\n        \"then\": { \"decision\": \"surcharge\" }\n      },\n      {\n        \"id\": \"r3\",\n        \"name\": \"USD payment\",\n        \"when\": [{ \"field\": \"currency\", \"op\": \"eq\", \"value\": \"USD\" }],\n        \"then\": { \"decision\": \"fx_review\" }\n      }\n    ],\n    \"default\": { \"decision\": \"approve\" }\n  }\n}"
            }
          }
        },
        {
          "name": "Update draft DSL (invalid — unknown field)",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/v1/rulesets/{{ruleset_key}}/draft?workspace={{workspace}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "rulesets", "{{ruleset_key}}", "draft"],
              "query": [{ "key": "workspace", "value": "{{workspace}}" }]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dsl\": {\n    \"dsl_version\": \"v1\",\n    \"strategy\": \"first_match\",\n    \"schema\": {\n      \"amount\": { \"type\": \"number\" }\n    },\n    \"rules\": [\n      {\n        \"id\": \"r1\",\n        \"name\": \"Bad rule\",\n        \"when\": [{ \"field\": \"nonexistent_field\", \"op\": \"gt\", \"value\": 100 }],\n        \"then\": { \"decision\": \"fail\" }\n      }\n    ]\n  }\n}"
            }
          }
        },
        {
          "name": "Delete draft",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/v1/rulesets/{{ruleset_key}}/draft?workspace={{workspace}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "rulesets", "{{ruleset_key}}", "draft"],
              "query": [{ "key": "workspace", "value": "{{workspace}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Publish",
      "item": [
        {
          "name": "Publish ruleset",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/v1/rulesets/{{ruleset_key}}/publish?workspace={{workspace}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "rulesets", "{{ruleset_key}}", "publish"],
              "query": [{ "key": "workspace", "value": "{{workspace}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Versions",
      "item": [
        {
          "name": "List versions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/rulesets/{{ruleset_key}}/versions?workspace={{workspace}}&limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["v1", "rulesets", "{{ruleset_key}}", "versions"],
              "query": [
                { "key": "workspace", "value": "{{workspace}}" },
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Get latest version",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/rulesets/{{ruleset_key}}/versions/latest?workspace={{workspace}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "rulesets", "{{ruleset_key}}", "versions", "latest"],
              "query": [{ "key": "workspace", "value": "{{workspace}}" }]
            }
          }
        },
        {
          "name": "Get specific version",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/rulesets/{{ruleset_key}}/versions/1?workspace={{workspace}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "rulesets", "{{ruleset_key}}", "versions", "1"],
              "query": [{ "key": "workspace", "value": "{{workspace}}" }]
            }
          }
        },
        {
          "name": "Download latest bundle",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/rulesets/{{ruleset_key}}/versions/latest/bundle?workspace={{workspace}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "rulesets", "{{ruleset_key}}", "versions", "latest", "bundle"],
              "query": [{ "key": "workspace", "value": "{{workspace}}" }]
            }
          }
        },
        {
          "name": "Download specific version bundle",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/rulesets/{{ruleset_key}}/versions/1/bundle?workspace={{workspace}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "rulesets", "{{ruleset_key}}", "versions", "1", "bundle"],
              "query": [{ "key": "workspace", "value": "{{workspace}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Users",
          "item": [
            {
              "name": "List users",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/v1/admin/users?limit=50&offset=0",
                  "host": ["{{base_url}}"],
                  "path": ["v1", "admin", "users"],
                  "query": [
                    { "key": "limit", "value": "50" },
                    { "key": "offset", "value": "0" }
                  ]
                }
              }
            },
            {
              "name": "Delete user",
              "request": {
                "method": "DELETE",
                "url": "{{base_url}}/v1/admin/users/{{user_id}}"
              }
            }
          ]
        },
        {
          "name": "Roles",
          "item": [
            {
              "name": "List user roles",
              "request": {
                "method": "GET",
                "url": "{{base_url}}/v1/admin/users/{{user_id}}/roles"
              }
            },
            {
              "name": "Set role on workspace",
              "request": {
                "method": "PUT",
                "url": "{{base_url}}/v1/admin/users/{{user_id}}/roles/{{workspace}}",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"role_mask\": 3\n}"
                }
              }
            },
            {
              "name": "Remove role on workspace",
              "request": {
                "method": "DELETE",
                "url": "{{base_url}}/v1/admin/users/{{user_id}}/roles/{{workspace}}"
              }
            }
          ]
        },
        {
          "name": "API Keys",
          "item": [
            {
              "name": "Create API key",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "var r = pm.response.json();",
                      "if (r.id) pm.collectionVariables.set('key_id', r.id);"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "url": "{{base_url}}/v1/admin/keys",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"ci-pipeline\",\n  \"workspace\": \"{{workspace}}\",\n  \"role\": 3,\n  \"expires_in_days\": 90\n}"
                }
              }
            },
            {
              "name": "List API keys",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/v1/admin/keys?limit=50&offset=0",
                  "host": ["{{base_url}}"],
                  "path": ["v1", "admin", "keys"],
                  "query": [
                    { "key": "limit", "value": "50" },
                    { "key": "offset", "value": "0" }
                  ]
                }
              }
            },
            {
              "name": "Revoke API key",
              "request": {
                "method": "DELETE",
                "url": "{{base_url}}/v1/admin/keys/{{key_id}}"
              }
            }
          ]
        }
      ]
    }
  ]
}
